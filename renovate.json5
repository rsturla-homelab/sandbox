{
    "$schema": "https://docs.renovatebot.com/renovate-schema.json",
    // Use the basic Renovate preset, and allow settings to be overridden
    "extends": [
        "config:best-practices"
    ],
    "packageRules": [
        {
            // Disable major version updates for Docker images
            "matchDatasources": [
                "docker"
            ],
            "matchUpdateTypes": [
                "major"
            ],
            "enabled": false
        }
    ],
    "customManagers": [
        {
            "customType": "regex",
            "fileMatch": [
                "^image-versions\\.yaml$"
            ],
            "matchStrings": [
                "name:\\s*(?<depName>\\S+)\\s*image:\\s*(?<packageName>\\S+)\\s*version:\\s*(?<currentValue>\\S+)\\s*digest:\\s*(?<currentDigest>sha256:[a-f0-9]+)"
            ],
            "datasourceTemplate": "docker"
        }
    ]
}