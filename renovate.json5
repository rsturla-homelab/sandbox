{
    "$schema": "https://docs.renovatebot.com/renovate-schema.json",
    // Use the basic Renovate preset, and allow settings to be overridden
    "extends": [
        "config:best-practices"
    ],
    "packageRules": [
        {
            // Disable major version updates for Docker images
            "matchDatasources": [
                "docker"
            ],
            "matchUpdateTypes": [
                "major"
            ],
            "enabled": false
        }
    ],
    "customManagers": [
        {
            "customType": "regex",
            "fileMatch": [
                "^image-versions\\.yaml$"
            ],
            "matchStrings": [
                "image:\\s*(?<packageName>\\S+)\\s*tag:\\s*(?<currentValue>\\S+)\\s*digest:\\s*(?<currentDigest>sha256:[a-f0-9]+)"
            ],
            "datasourceTemplate": "docker"
        },
        {
            "customType": "regex",
            "managerFilePatterns": ["^Casks/.*\\.rb$"],
            "matchStrings": [
                "# renovate: datasource=(?<datasource>[a-z-]+?) depName=(?<depName>[^\\s]+)\n[\\s\\S]*?version\\s+\"(?<currentValue>[^\"]+)\"(?:[\\s\\S]*?sha256\\s+\"?(?<currentDigest>[a-f0-9]+|:no_check)\"?)?"
            ],
            "versioningTemplate": "semver"
        }
    ]
}
