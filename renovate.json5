{
    "$schema": "https://docs.renovatebot.com/renovate-schema.json",
    // Use the basic Renovate preset, and allow settings to be overridden
    "extends": [
        "config:best-practices"
    ],
    "packageRules": [
        {
            // Disable major version updates for Docker images
            "matchDatasources": [
                "docker"
            ],
            "matchUpdateTypes": [
                "major"
            ],
            "enabled": false
        }
    ],
    "customManagers": [
        {
            "customType": "regex",
            "fileMatch": [
                "^image-versions\\.yaml$"
            ],
            "matchStrings": [
                "name:\\s*(?P<depName>\\S+)\\s*image:\\s*(?P<packageName>\\S+)\\s*version:\\s*(?P<currentValue>\\S+)\\s*digest:\\s*(?P<currentDigest>sha256:[a-f0-9]+)"
            ],
            "datasourceTemplate": "docker",
            "versioningTemplate": "loose",
            "currentValueTemplate": "{{{currentValue}}}",
            "depNameTemplate": "{{{depName}}}",
            "packageNameTemplate": "{{{packageName}}}",
            "currentDigestTemplate": "{{{currentDigest}}}"
        }
    ]
}